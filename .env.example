# Copy this file to .env for local Docker Compose runs.
# Do not commit a real .env file.

# Generate with: openssl rand -base64 32
JWT_SECRET_KEY=replace-with-generated-base64-secret

POSTGRES_DB=spring_boot_jwt_auth
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Used when running the app directly from IntelliJ/Maven.
DB_URL=jdbc:postgresql://localhost:5432/spring_boot_jwt_auth
DB_USERNAME=postgres
DB_PASSWORD=postgres

CORS_ALLOWED_ORIGINS=http://localhost:3000

JWT_EXPIRATION_MS=1800000
JWT_REFRESH_EXPIRATION_MS=5184000000

LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCK_DURATION=15m

REFRESH_COOKIE_NAME=refreshToken
REFRESH_COOKIE_PATH=/api/auth/web
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAME_SITE=Lax
REFRESH_COOKIE_MAX_AGE_SECONDS=5184000

CSRF_COOKIE_PATH=/
CSRF_COOKIE_SECURE=false
CSRF_COOKIE_SAME_SITE=Lax
